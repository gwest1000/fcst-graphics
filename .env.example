# R2 S3 API credentials. Keep the populated file outside Git.
FCST_R2_ACCOUNT_ID=
FCST_R2_ACCESS_KEY_ID=
FCST_R2_SECRET_ACCESS_KEY=
FCST_R2_BUCKET=fcst-graphics

# Start with the public r2.dev URL, then replace it with the custom-domain URL.
FCST_R2_PUBLIC_BASE_URL=https://example.r2.dev
FCST_R2_UPLOAD_WORKERS=2
